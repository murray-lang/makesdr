{
  "version": 3,
  "configurePresets": [
    {
      "name": "linux-play-debug",
      "displayName": "Play Debug (linux)",
      "binaryDir": "${sourceDir}/build-play-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TARGET_EXAMPLE": "play",
        "TARGET_PLATFORM": "linux"
      }
    },
    {
      "name": "linux-play-release",
